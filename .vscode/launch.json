{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch debug development",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "debug",
      "debuggerType": "flutter",
      "toolArgs": ["--flavor", "development"]
    },
    {
      "name": "Launch profile development",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "toolArgs": ["--flavor", "development"]
    },
    {
      "name": "Launch staging (TestFlight)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "profile",
      "toolArgs": ["--flavor", "staging"]
    },
    {
      "name": "Launch production (Release)",
      "request": "launch",
      "type": "dart",
      "program": "lib/main.dart",
      "flutterMode": "release",
      "toolArgs": [
        "--flavor",
        "production",
        "--build-number $(TZ='Asia/Seoul' date +'%y%m%d%H')"
      ]
    },
    {
      "name": "Flutter Test (Random Order)",
      "type": "dart",
      "request": "launch",
      "program": "test",
      "toolArgs": [
        "--concurrency 2",
        "--coverage",
        "--dart-define",
        "FLUTTER_TEST=true",
        "--test-randomize-ordering-seed random"
      ]
    }
  ]
}
